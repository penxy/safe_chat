prefix=/home/pxy/libs/Qt5
exec_prefix=${prefix}
libdir=${prefix}/lib
includedir=${prefix}/include


Name: Qt5 OpenGLExtensions
Description: Qt OpenGLExtensions module
Version: 5.14.2
Libs: -L${libdir} -lQt5OpenGLExtensions 
